{
  "name": "school-finder-scraper-admin",
  "version": "1.0.0",
  "description": "Panel administracyjny dla scraperów School Finder",
  "main": "scraper-server.js",
  "scripts": {
    "start": "node scraper-server.js",
    "scraper": "cd school-finder-scraper && python main.py",
    "scraper:full": "cd school-finder-scraper && python main.py --mode=full",
    "scraper:test": "cd school-finder-scraper && python main.py --mode=test --limit=10"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "@supabase/supabase-js": "^2.31.0",
    "dotenv": "^16.3.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}